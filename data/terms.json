  { "id": "t249", "category": "lab", "en": "Pregnancy test", "de": "Schwangerschaftstest", "ar": "اختبار الحمل" },
  { "id": "t250", "category": "lab", "en": "Urine test strip", "de": "Urinteststreifen", "ar": "شريط فحص البول" },

  { "id": "t251", "category": "phrase", "en": "Take once daily.", "de": "Einmal täglich einnehmen.", "ar": "يؤخذ مرة واحدة يومياً." },
  { "id": "t252", "category": "phrase", "en": "Take twice daily.", "de": "Zweimal täglich einnehmen.", "ar": "يؤخذ مرتين يومياً." },
  { "id": "t253", "category": "phrase", "en": "Take three times daily.", "de": "Dreimal täglich einnehmen.", "ar": "يؤخذ ثلاث مرات يومياً." },
  { "id": "t254", "category": "phrase", "en": "Take after meals.", "de": "Nach dem Essen einnehmen.", "ar": "يؤخذ بعد الطعام." },
  { "id": "t255", "category": "phrase", "en": "Take before meals.", "de": "Vor dem Essen einnehmen.", "ar": "يؤخذ قبل الطعام." },
  { "id": "t256", "category": "phrase", "en": "Take on an empty stomach.", "de": "Auf nüchternen Magen einnehmen.", "ar": "يؤخذ على معدة فارغة." },
  { "id": "t257", "category": "phrase", "en": "Take with plenty of water.", "de": "Mit reichlich Wasser einnehmen.", "ar": "يؤخذ مع كمية وفيرة من الماء." },
  { "id": "t258", "category": "phrase", "en": "Do you have any allergies?", "de": "Haben Sie Allergien?", "ar": "هل لديك أي حساسية؟" },
  { "id": "t259", "category": "phrase", "en": "Are you pregnant or breastfeeding?", "de": "Sind Sie schwanger oder stillen Sie?", "ar": "هل أنتِ حامل أو مرضع؟" },
  { "id": "t260", "category": "phrase", "en": "Are you taking any other medication?", "de": "Nehmen Sie andere Medikamente ein?", "ar": "هل تتناول أدوية أخرى؟" },

  { "id": "t261", "category": "phrase", "en": "Do you have a prescription?", "de": "Haben Sie ein Rezept?", "ar": "هل لديك وصفة طبية؟" },
  { "id": "t262", "category": "phrase", "en": "Do you have your insurance card?", "de": "Haben Sie Ihre Versichertenkarte?", "ar": "هل لديك بطاقة التأمين؟" },
  { "id": "t263", "category": "phrase", "en": "This medication requires a prescription.", "de": "Dieses Medikament ist verschreibungspflichtig.", "ar": "هذا الدواء يحتاج إلى وصفة طبية." },
  { "id": "t264", "category": "phrase", "en": "This is available over the counter.", "de": "Das ist rezeptfrei erhältlich.", "ar": "هذا متاح بدون وصفة." },
  { "id": "t265", "category": "phrase", "en": "Please read the package insert.", "de": "Bitte lesen Sie die Packungsbeilage.", "ar": "يرجى قراءة النشرة الداخلية." },
  { "id": "t266", "category": "phrase", "en": "Side effects may include drowsiness.", "de": "Nebenwirkungen können Müdigkeit umfassen.", "ar": "قد تشمل الآثار الجانبية النعاس." },
  { "id": "t267", "category": "phrase", "en": "Do not drive while taking this medicine.", "de": "Fahren Sie nicht, während Sie dieses Medikament einnehmen.", "ar": "لا تقد السيارة أثناء تناول هذا الدواء." },
  { "id": "t268", "category": "phrase", "en": "Avoid alcohol with this medication.", "de": "Vermeiden Sie Alkohol bei diesem Medikament.", "ar": "تجنب الكحول مع هذا الدواء." },
  { "id": "t269", "category": "phrase", "en": "Store in a cool, dry place.", "de": "Kühl und trocken lagern.", "ar": "يُحفظ في مكان بارد وجاف." },
  { "id": "t270", "category": "phrase", "en": "Keep out of reach of children.", "de": "Außerhalb der Reichweite von Kindern aufbewahren.", "ar": "يُحفظ بعيداً عن متناول الأطفال." },

  { "id": "t271", "category": "phrase", "en": "If symptoms persist, see a doctor.", "de": "Wenn die Beschwerden anhalten, suchen Sie einen Arzt auf.", "ar": "إذا استمرت الأعراض، استشر الطبيب." },
  { "id": "t272", "category": "phrase", "en": "How long have you had these symptoms?", "de": "Wie lange haben Sie die Beschwerden schon?", "ar": "منذ متى وأنت تعاني من هذه الأعراض؟" },
  { "id": "t273", "category": "phrase", "en": "Have you taken anything for it?", "de": "Haben Sie schon etwas dagegen genommen?", "ar": "هل تناولت شيئاً لذلك؟" },
  { "id": "t274", "category": "phrase", "en": "Is the medicine for you or someone else?", "de": "Ist das Medikament für Sie oder jemand anderen?", "ar": "هل الدواء لك أم لشخص آخر؟" },
  { "id": "t275", "category": "phrase", "en": "How old is the patient?", "de": "Wie alt ist die Patientin / der Patient?", "ar": "كم عمر المريض؟" },
  { "id": "t276", "category": "phrase", "en": "Do you have any chronic illnesses?", "de": "Haben Sie chronische Erkrankungen?", "ar": "هل لديك أمراض مزمنة؟" },
  { "id": "t277", "category": "phrase", "en": "I will check the stock.", "de": "Ich schaue im Lager nach.", "ar": "سأتحقق من المخزون." },
  { "id": "t278", "category": "phrase", "en": "We can order it for tomorrow.", "de": "Wir können es bis morgen bestellen.", "ar": "يمكننا طلبه ليوم غد." },
  { "id": "t279", "category": "phrase", "en": "The co-payment is 5 euros.", "de": "Die Zuzahlung beträgt 5 Euro.", "ar": "المساهمة الشخصية 5 يورو." },
  { "id": "t280", "category": "phrase", "en": "Would you like a generic equivalent?", "de": "Möchten Sie ein günstigeres Generikum?", "ar": "هل تريد بديلاً جنيساً (Generikum)؟" },

  { "id": "t281", "category": "phrase", "en": "Please shake well before use.", "de": "Vor Gebrauch gut schütteln.", "ar": "يُرج جيداً قبل الاستعمال." },
  { "id": "t282", "category": "phrase", "en": "Use within 4 weeks of opening.", "de": "Nach dem Anbruch innerhalb von 4 Wochen verwenden.", "ar": "يُستعمل خلال 4 أسابيع من فتح العبوة." },
  { "id": "t283", "category": "phrase", "en": "Refrigerate after opening.", "de": "Nach dem Öffnen im Kühlschrank lagern.", "ar": "يُحفظ في الثلاجة بعد فتحه." },
  { "id": "t284", "category": "phrase", "en": "Do not exceed the recommended dose.", "de": "Überschreiten Sie nicht die empfohlene Dosis.", "ar": "لا تتجاوز الجرعة الموصى بها." },
  { "id": "t285", "category": "phrase", "en": "If you miss a dose, take it as soon as possible.", "de": "Wenn Sie eine Dosis vergessen haben, holen Sie sie so bald wie möglich nach.", "ar": "إذا نسيت جرعة فتناولها في أقرب وقت ممكن." },
  { "id": "t286", "category": "phrase", "en": "Do not take a double dose.", "de": "Nehmen Sie nicht die doppelte Dosis ein.", "ar": "لا تتناول جرعة مضاعفة." },
  { "id": "t287", "category": "phrase", "en": "Complete the full course of antibiotics.", "de": "Nehmen Sie die Antibiotika bis zum Ende ein.", "ar": "أكمل دورة المضاد الحيوي كاملة." },
  { "id": "t288", "category": "phrase", "en": "Tell me where the pain is.", "de": "Zeigen Sie mir, wo es weh tut.", "ar": "أرني أين يوجد الألم." },
  { "id": "t289", "category": "phrase", "en": "Is the pain sharp or dull?", "de": "Ist der Schmerz stechend oder dumpf?", "ar": "هل الألم حاد أم خفيف؟" },
  { "id": "t290", "category": "phrase", "en": "Does the pain radiate?", "de": "Strahlt der Schmerz aus?", "ar": "هل ينتشر الألم؟" },

  { "id": "t291", "category": "phrase", "en": "I recommend you see a doctor.", "de": "Ich empfehle Ihnen, einen Arzt aufzusuchen.", "ar": "أنصحك بمراجعة الطبيب." },
  { "id": "t292", "category": "phrase", "en": "This may interact with your other medication.", "de": "Das kann mit Ihren anderen Medikamenten Wechselwirkungen haben.", "ar": "قد يتفاعل هذا مع أدويتك الأخرى." },
  { "id": "t293", "category": "phrase", "en": "Have you been vaccinated?", "de": "Sind Sie geimpft?", "ar": "هل أخذت اللقاح؟" },
  { "id": "t294", "category": "phrase", "en": "Drink plenty of fluids.", "de": "Trinken Sie viel Flüssigkeit.", "ar": "اشرب الكثير من السوائل." },
  { "id": "t295", "category": "phrase", "en": "Get plenty of rest.", "de": "Ruhen Sie sich gut aus.", "ar": "احصل على راحة كافية." },
  { "id": "t296", "category": "phrase", "en": "Take this medicine every 8 hours.", "de": "Nehmen Sie dieses Medikament alle 8 Stunden ein.", "ar": "تناول هذا الدواء كل 8 ساعات." },
  { "id": "t297", "category": "phrase", "en": "The treatment lasts seven days.", "de": "Die Behandlung dauert sieben Tage.", "ar": "تستغرق المعالجة سبعة أيام." },
  { "id": "t298", "category": "phrase", "en": "Apply a thin layer to the affected area.", "de": "Tragen Sie eine dünne Schicht auf die betroffene Stelle auf.", "ar": "ضع طبقة رقيقة على المنطقة المصابة." },
  { "id": "t299", "category": "phrase", "en": "For external use only.", "de": "Nur zur äußerlichen Anwendung.", "ar": "للاستعمال الخارجي فقط." },
  { "id": "t300", "category": "phrase", "en": "Do you have private or public insurance?", "de": "Sind Sie privat oder gesetzlich versichert?", "ar": "هل تأمينك خاص أم قانوني (حكومي)؟" }
]
